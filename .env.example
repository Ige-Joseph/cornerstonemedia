# Corner Stone Media — Frontend Environment
# Copy to .env.local for local development

# Backend API URL — must include /api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# WhatsApp business number (international format, no + or spaces)
# Update in: src/components/ui/WhatsAppButton.tsx → WHATSAPP_NUMBER
# Example: 2348012345678 = +234 (Nigeria) 0812345678
NEXT_PUBLIC_WHATSAPP_NUMBER=2348000000000

# Production site URL — used for sitemap.xml and SEO metadata
# Update this to your actual domain when deploying
NEXT_PUBLIC_SITE_URL=https://cornerstonemedia.com
